{
	"name": "@sondr3/astro-compressor",
	"version": "1.3.0",
	"private": true,
	"description": "A gzip, brotli and zstd compressor for Astro",
	"scripts": {
		"dev": "pnpm run -r dev",
		"build": "pnpm run --filter 'astro-compressor' -r build",
		"test": "pnpm run -r test",
		"prepare": "lefthook install",
		"check": "oxlint && oxfmt --check",
		"fix": "oxlint --fix && oxfmt"
	},
	"devDependencies": {
		"lefthook": "2.1.6",
		"oxfmt": "0.46.0",
		"oxlint": "1.61.0",
		"oxlint-tsgolint": "0.21.1"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@10.33.1"
}
